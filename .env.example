# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it's already in .gitignore.

# Anthropic Claude API — https://console.anthropic.com/settings/keys
	
	#Claude API Key
	VITE_ANTHROPIC_API_KEY=sk-ant-...

# Open WebUI — local LLM server

	# URL of your Open WebUI instance
	VITE_OPENWEBUI_URL=http://URL-IP:port

	# API key from Open WebUI → User icon → Account → API Keys → Create new secret key
	VITE_OPENWEBUI_API_KEY=

# Supabase — https://supabase.com/dashboard/project/_/settings/api

	# Project URL (Settings → API → Project URL)
	VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

	# Anon/public key — safe to use in frontend code (RLS enforces access control)
	VITE_SUPABASE_ANON_KEY=

	# Service role key — used for schema setup ONLY, never put this in frontend app code
	SUPABASE_SERVICE_KEY=

	# Classic Access Key
	SUPABASE_MANAGEMENT_TOKEN=your-classic-access-token

#Tavily -- https://www.tavily.com/
	
	#Tavily Agent Web Search
	VITE_TAVILY_API_KEY=
	
#Google Cloud API -- https://console.cloud.google.com/apis/credentials

	# Web application client (used for future server-side flows)
	VITE_GOOGLE_WEBCLIENT_ID=
	VITE_GOOGLE_WEBCLIENT_SECRET=

	# Desktop app client — used for all Google OAuth2 PKCE flows (Gmail, Calendar, Drive, Docs, Sheets, Slides)
	VITE_GOOGLE_DESKTOPCLIENT_ID=
	VITE_GOOGLE_DESKTOPCLIENT_SECRET=

	# Browser API key — required for the Google Picker file-selection widget
	# Create at: Google Cloud Console → APIs & Services → Credentials → Create Credentials → API Key
	VITE_GOOGLE_BROWSER_API_KEY=

# GitHub — https://github.com/settings/tokens

	# Personal Access Token (classic) with repo scope — used for GitHub API and remote push
	GITHUB_TOKEN=ghp_...